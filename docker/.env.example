################################################################################
# .env.example — Environment Variable Template for Netmaker Docker Stack
#
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in ALL required values
#   3. NEVER commit the .env file to git — it contains secrets!
#
# The setup.sh script will auto-generate .env from this template interactively.
################################################################################

# ── Domain Configuration ─────────────────────────────────────────────────────
# Your base domain. DNS A records must point to this server's IP before starting.
# Example: vpn.example.com
BASE_DOMAIN=your.domain.com

# Public IP address of THIS server (obtained automatically by setup.sh)
SERVER_HOST=0.0.0.0

# ── Netmaker API Security ────────────────────────────────────────────────────
# Master key to protect the Netmaker API root endpoints.
# REQUIRED — Generate with: openssl rand -hex 32
MASTER_KEY=changemeplease_use_openssl_rand_hex_32

# ── MQTT Broker Credentials ──────────────────────────────────────────────────
# Used by the Netmaker server and all enrolled nodes to authenticate to Mosquitto.
# Username must be alphanumeric only.
MQ_USERNAME=netmaker
MQ_PASSWORD=changeme_use_a_strong_password_here

# ── Database (Optional — for PostgreSQL HA mode) ────────────────────────────
# Uncomment and configure if you change DATABASE=postgres in docker-compose.yml
# POSTGRES_USER=netmaker
# POSTGRES_PASSWORD=changeme_strong_db_password
# POSTGRES_DB=netmaker

# ── Feature Flags ────────────────────────────────────────────────────────────
# Show WireGuard private keys inside the UI (disable in production)
DISPLAY_KEYS=false

# Verbosity level: 0=error 1=info 2=debug
VERBOSITY=1

# Metrics exporter for Prometheus/Grafana integration
METRICS_EXPORTER=off
